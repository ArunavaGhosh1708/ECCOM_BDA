            ]
          }
        }
      },

      { "type": "row", "title": "Per-Service Request Rates", "id": 20, "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }, "collapsed": false },

      {
        "id": 21,
        "title": "App Service — Request Rate",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 23, "w": 6, "h": 7 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          { "expr": "sum(rate({app=\"trendtrove-app\"} | json [1m]))", "refId": "A", "legendFormat": "requests/s" }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "#1F60C4" }, "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
      },

      {
        "id": 22,
        "title": "Auth Service — Request Rate",
        "type": "timeseries",
        "gridPos": { "x": 6, "y": 23, "w": 6, "h": 7 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          { "expr": "sum(rate({app=\"trendtrove-auth\"} | json [1m]))", "refId": "A", "legendFormat": "requests/s" }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "#1F60C4" }, "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
      },

      {
        "id": 23,
        "title": "Product Service — Request Rate",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 23, "w": 6, "h": 7 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          { "expr": "sum(rate({app=\"trendtrove-app\"} | json | http_path=~\"/products.*\" [1m]))", "refId": "A", "legendFormat": "requests/s" }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "#1F60C4" }, "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
      },

      {
        "id": 24,
        "title": "Cart Service — Request Rate",
        "type": "timeseries",
        "gridPos": { "x": 18, "y": 23, "w": 6, "h": 7 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          { "expr": "sum(rate({app=\"cart-service\"} | json [1m]))", "refId": "A", "legendFormat": "requests/s" }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "#1F60C4" }, "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
      },

      {
        "id": 25,
        "title": "Error Rate by Service",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 30, "w": 24, "h": 8 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          { "expr": "sum(rate({app=\"trendtrove-app\"} | json | level=\"ERROR\" [1m]))", "refId": "A", "legendFormat": "app-service" },
          { "expr": "sum(rate({app=\"trendtrove-auth\"} | json | level=\"ERROR\" [1m]))", "refId": "B", "legendFormat": "auth-service" },
          { "expr": "sum(rate({app=\"cart-service\"} | json | level=\"ERROR\" [1m]))", "refId": "C", "legendFormat": "cart-service" },
          { "expr": "sum(rate({app=\"trendtrove-app-v2\"} | json | level=\"ERROR\" [1m]))", "refId": "D", "legendFormat": "app-v2 (canary)" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
          "overrides": [
            { "matcher": { "id": "byName", "options": "app-service" },     "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
            { "matcher": { "id": "byName", "options": "auth-service" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
            { "matcher": { "id": "byName", "options": "cart-service" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
            { "matcher": { "id": "byName", "options": "app-v2 (canary)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      }

    ],
    "schemaVersion": 36
  },
  "overwrite": true,
  "folderId": 0
}
