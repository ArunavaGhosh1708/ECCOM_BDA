{
  "dashboard": {
    "title": "TrendTrove — Service Graph",
    "tags": ["trendtrove", "service-graph"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-15m", "to": "now" },
    "panels": [

      {
        "id": 1,
        "title": "Service Topology",
        "description": "Service map. To draw arrows: click a box edge anchor (circle), drag to target box. Green=app routing, Orange=DB, Blue=telemetry.",
        "type": "canvas",
        "gridPos": { "x": 0, "y": 0, "w": 24, "h": 22 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          { "expr": "sum(rate({app=\"trendtrove-app\"} | json [2m]))", "refId": "A", "instant": true, "legendFormat": "app" },
          { "expr": "sum(rate({app=\"trendtrove-auth\"} | json [2m]))", "refId": "B", "instant": true, "legendFormat": "auth" },
          { "expr": "sum(rate({app=\"cart-service\"} | json [2m]))", "refId": "C", "instant": true, "legendFormat": "cart" },
          { "expr": "sum(rate({app=\"trendtrove-app-v2\"} | json [2m]))", "refId": "D", "instant": true, "legendFormat": "app-v2" },
          { "expr": "sum(rate({app=\"trendtrove-app-v3\"} | json [2m]))", "refId": "E", "instant": true, "legendFormat": "app-v3" }
        ],
        "transformations": [
          { "id": "reduce", "options": { "reducers": ["lastNotNull"] } }
        ],
        "options": {
          "inlineEditing": true,
          "panZoom": false,
          "tooltip": { "mode": "single" },
          "root": {
            "type": "frame",
            "name": "root",
            "placement": { "left": 0, "top": 0, "width": 100, "height": 100, "rotation": 0 },
            "background": { "color": { "fixed": "transparent" } },
            "border": { "color": { "fixed": "transparent" } },
            "elements": [

              {
                "type": "rectangle",
                "name": "app-service",
                "placement": { "left": 36, "top": 4, "width": 18, "height": 14, "rotation": 0 },
                "background": { "color": { "fixed": "#1F60C4" } },
                "border": { "color": { "fixed": "#5794F2" } },
                "config": {
                  "text": { "fixed": "App Service" },
                  "align": "center",
                  "valign": "middle",
                  "color": { "fixed": "#FFFFFF" },
                  "size": 16
                },
                "connections": []
              },

