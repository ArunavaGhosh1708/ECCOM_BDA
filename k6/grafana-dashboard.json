{
  "dashboard": {
    "title": "TrendTrove — Application Observability",
    "tags": ["trendtrove", "loki", "k6"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-30m", "to": "now" },
    "panels": [

      { "type": "row", "title": "Developer — Traffic & Errors", "id": 1, "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

      {
        "id": 2,
        "title": "Log Volume by Level",
        "description": "Rate of log lines per level across all app services. Spikes in ERROR/WARN indicate problems.",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum by (level) (rate({app=~\"trendtrove-app|trendtrove-auth|cart-service\"} | json | level != \"\" [1m]))",
            "refId": "A",
            "legendFormat": "{{level}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
          "overrides": [
            { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
            { "matcher": { "id": "byName", "options": "WARN" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
            { "matcher": { "id": "byName", "options": "INFO" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      },

      {
        "id": 3,
        "title": "HTTP Request Rate by Path",
        "description": "Which endpoints are being hit most. Useful for spotting unexpected traffic patterns.",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "topk(8, sum by (http_path) (rate({app=~\"trendtrove-app|trendtrove-auth|cart-service\"} | json | http_path != \"\" [1m])))",
            "refId": "A",
            "legendFormat": "{{http_path}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps" } },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      },

      {
        "id": 4,
        "title": "HTTP Status Code Distribution",
        "description": "Breakdown of response codes. 4xx = client errors, 5xx = server errors.",
        "type": "piechart",
        "gridPos": { "x": 0, "y": 9, "w": 8, "h": 8 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum by (http_status_code) (count_over_time({app=~\"trendtrove-app|trendtrove-auth|cart-service\"} | json | http_status_code != \"\" [$__range]))",
            "refId": "A",
            "legendFormat": "{{http_status_code}}",
            "instant": true
          }
        ],
        "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut" }
      },

      {
        "id": 5,
        "title": "Error Count",
        "description": "Total ERROR log lines in the selected time range.",
        "type": "stat",
        "gridPos": { "x": 8, "y": 9, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum(count_over_time({app=~\"trendtrove-app|trendtrove-auth|cart-service\"} | json | level=\"ERROR\" [$__range]))",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] },
            "color": { "mode": "thresholds" }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
      },

      {
        "id": 6,
        "title": "Warning Count",
        "description": "Total WARN log lines in the selected time range.",
        "type": "stat",
        "gridPos": { "x": 8, "y": 13, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum(count_over_time({app=~\"trendtrove-app|trendtrove-auth|cart-service\"} | json | level=\"WARN\" [$__range]))",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "green" }, { "value": 5, "color": "orange" }] },
            "color": { "mode": "thresholds" }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
      },

      {
        "id": 7,
        "title": "Recent Error Logs",
        "description": "Live stream of ERROR-level logs across all services. Use this to drill into failures.",
        "type": "logs",
        "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "{app=~\"trendtrove-app|trendtrove-auth|cart-service\"} | json | level=\"ERROR\"",
            "refId": "A"
          }
        ],
        "options": { "dedupStrategy": "none", "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true }
      },

      { "type": "row", "title": "App Owner — Business Metrics", "id": 10, "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 }, "collapsed": false },

      {
        "id": 11,
        "title": "Cart Items Added",
        "description": "How many items customers are adding to cart over time.",
        "type": "stat",
        "gridPos": { "x": 0, "y": 18, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum(count_over_time({app=~\"trendtrove-app|cart-service\"} | json | event=\"cart.item.added\" [$__range]))",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "blue" }] },
            "color": { "mode": "thresholds" }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
      },

      {
        "id": 12,
        "title": "Checkouts Initiated",
        "description": "Number of users who reached the checkout page.",
        "type": "stat",
        "gridPos": { "x": 4, "y": 18, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum(count_over_time({app=~\"trendtrove-app|cart-service\"} | json | event=\"checkout.initiated\" [$__range]))",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "purple" }] },
            "color": { "mode": "thresholds" }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
      },

      {
        "id": 13,
        "title": "Payments Initiated",
        "description": "Number of Stripe checkout sessions created — the deepest funnel stage.",
        "type": "stat",
        "gridPos": { "x": 8, "y": 18, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum(count_over_time({app=~\"trendtrove-app|cart-service\"} | json | event=\"payment.initiated\" [$__range]))",
            "refId": "A",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "green" }] },
            "color": { "mode": "thresholds" }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
      },

      {
        "id": 14,
        "title": "Purchase Funnel Over Time",
        "description": "Tracks how users move through the buying journey. A drop between stages shows where users abandon.",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum(rate({app=~\"trendtrove-app|cart-service\"} | json | event=\"cart.item.added\" [2m]))",
            "refId": "A",
            "legendFormat": "Items Added"
          },
          {
            "expr": "sum(rate({app=~\"trendtrove-app|cart-service\"} | json | event=\"checkout.initiated\" [2m]))",
            "refId": "B",
            "legendFormat": "Checkout Initiated"
          },
          {
            "expr": "sum(rate({app=~\"trendtrove-app|cart-service\"} | json | event=\"payment.initiated\" [2m]))",
            "refId": "C",
            "legendFormat": "Payment Initiated"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
          "overrides": [
            { "matcher": { "id": "byName", "options": "Items Added" },       "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
            { "matcher": { "id": "byName", "options": "Checkout Initiated" },"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }] },
            { "matcher": { "id": "byName", "options": "Payment Initiated" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      },

      {
        "id": 15,
        "title": "Business Events by Category",
        "description": "Rate of events grouped by category (cart_checkout, payment_fraud, auth, system).",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum by (category) (rate({app=~\"trendtrove-app|trendtrove-auth|cart-service\"} | json | category != \"\" [1m]))",
            "refId": "A",
            "legendFormat": "{{category}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps" } },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      },

      {
        "id": 16,
        "title": "Auth Events (Logins & Signups)",
        "description": "Login and signup activity over time. Sudden auth.failed spikes may indicate brute-force attempts.",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "ffh82mih4h2pse" },
        "targets": [
          {
            "expr": "sum by (event) (rate({app=\"trendtrove-auth\"} | json | event != \"\" [1m]))",
            "refId": "A",
            "legendFormat": "{{event}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps" } },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      }

    ],
    "schemaVersion": 36
  },
  "overwrite": true,
  "folderId": 0
}
